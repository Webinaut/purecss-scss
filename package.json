{
  "name": "purecss-scss",
  "version": "2.0.5",
  "description": "Pure CSS framework, converted to Sass (SCSS) and ready to use in Sass powered applications",
  "keywords": [
    "pure",
    "purecss",
    "scss",
    "sass"
  ],
  "main": "dist/pure.css",
  "scss": "src/pure.scss",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "modern-normalize": "^3.0.1",
    "sass": "^1.99.0"
  },
  "scripts": {
    "build": "sass src/pure.scss dist/pure.css --style compressed",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
